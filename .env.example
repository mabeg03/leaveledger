# PostgreSQL (Neon recommended — free tier)
DATABASE_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require"

# Required — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="your-secret-here"

# Required in production — your full app URL (no trailing slash)
AUTH_URL="http://localhost:3000"

# Optional legacy alias (Auth.js v5 prefers AUTH_URL)
NEXTAUTH_URL="http://localhost:3000"

# Optional: Google OAuth
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
